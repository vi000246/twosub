{
  "name": "twosub",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Bilingual (EN/ZH) dual-subtitle + instant word-learning browser extension for Netflix, YouTube, HBO Max.",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "wxt prepare && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@wxt-dev/module-react": "^1.1.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wxt": "^0.20.0"
  }
}
